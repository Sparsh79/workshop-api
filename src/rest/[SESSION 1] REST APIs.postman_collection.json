      "name": "Session 1 and 2: Basic APIs and Assertion",
      "item": [
        {
          "name": "Basic Crud Operation and API Validation",
          "item": [
            {
              "name": "GET_All_Available_Users",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 200', () => pm.response.to.have.status(200));",
                      "pm.test('Returns users', () => pm.expect(pm.response.json().data.length).to.be.greaterThan(0));",
                      "",
                      "pm.test(\"Validate users list schema\", function () {",
                      "    const schema = {",
                      "        type: \"object\",",
                      "        required: [\"data\", \"pagination\"],",
                      "        properties: {",
                      "            data: {",
                      "                type: \"array\",",
                      "                items: {",
                      "                    type: \"object\",",
                      "                    required: [",
                      "                        \"id\",",
                      "                        \"name\",",
                      "                        \"email\",",
                      "                        \"role\",",
                      "                        \"department\",",
                      "                        \"apiKey\",",
                      "                        \"avatar\",",
                      "                        \"isActive\",",
                      "                        \"createdAt\",",
                      "                        \"updatedAt\"",
                      "                    ],",
                      "                    properties: {",
                      "                        id: { type: \"string\" },",
                      "                        name: { type: \"string\" },",
                      "                        email: { type: \"string\", format: \"email\" },",
                      "                        role: { type: \"string\" },",
                      "                        department: { type: \"string\" },",
                      "                        apiKey: { type: \"string\" },",
                      "                        avatar: { type: \"string\", format: \"uri\" },",
                      "                        isActive: { type: \"boolean\" },",
                      "                        createdAt: { type: \"string\", format: \"date-time\" },",
                      "                        updatedAt: { type: \"string\", format: \"date-time\" }",
                      "                    }",
                      "                }",
                      "            },",
                      "            pagination: {",
                      "                type: \"object\",",
                      "                required: [\"page\", \"limit\", \"total\", \"totalPages\"],",
                      "                properties: {",
                      "                    page: { type: \"number\" },",
                      "                    limit: { type: \"number\" },",
                      "                    total: { type: \"number\" },",
                      "                    totalPages: { type: \"number\" }",
                      "                }",
                      "            }",
                      "        }",
                      "    };",
                      "",
                      "    pm.expect(pm.response.json()).to.have.jsonSchema(schema);",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "x-api-key",
                    "value": "ak-alice-001"
                  }
                ],
                "url": {
                  "raw": "{{restBase}}/users",
                  "host": [
                    "{{restBase}}"
                  ],
                  "path": [
                    "users"
                  ]
                }
              },
              "response": []
            },
            {
              "name": "POST_Create_New_User",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const r = pm.response.json();",
                      "pm.collectionVariables.set('newUserId', r.id);",
                      "pm.test('Status 201', () => pm.response.to.have.status(201));",
                      "pm.test('No password', () => pm.expect(r.password).to.be.undefined);",
                      "pm.test('Role should be present and match from the available roles', () => pm.expect(r.role).to.be.oneOf(['admin', 'user', 'guest']));",
                      "pm.test('Email should be present and match the email format', () => pm.expect(r.email).to.be.match(/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/));",
                      "pm.test(\"department should be present and match the available departments\", () => pm.expect(r.department).to.be.oneOf([\"QA\", \"Java\", \"Devops\", \"FE\"]));",
                      "pm.test(\"createdAt and updatedAt should be present and match the date format\", () => {",
                      "    pm.expect(r.createdAt).to.match(/^\\d{4}-\\d{2}-\\d{2}T\\d{2}/);",
                      "    pm.expect(r.updatedAt).to.match(/^\\d{4}-\\d{2}-\\d{2}T\\d{2}/);",
                      "});",
                      "",
                      "pm.test(\"Validate response schema\", function () {",
                      "    const schema = {",
                      "        type: \"object\",",
                      "        required: [",
                      "            \"id\", \"name\", \"email\", \"role\", \"department\",",
                      "            \"avatar\", \"isActive\", \"apiKey\", \"createdAt\", \"updatedAt\"",
                      "        ],",
                      "        properties: {",
                      "            id: { type: \"string\" },",
                      "            name: { type: \"string\" },",
                      "            email: { type: \"string\", format: \"email\" },",
                      "            role: { type: \"string\" },",
                      "            department: { type: \"string\" },",
                      "            avatar: { type: \"string\", format: \"uri\" },",
                      "            isActive: { type: \"boolean\" },",
                      "            apiKey: { type: \"string\" },",
                      "            createdAt: { type: \"string\", format: \"date-time\" },",
                      "            updatedAt: { type: \"string\", format: \"date-time\" }",
                      "        }",
                      "    };",
                      "",
                      "    pm.expect(pm.response.json()).to.have.jsonSchema(schema);",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                },
                {
                  "listen": "prerequest",
                  "script": {
                    "exec": [
                      "",
                      "// Select a random role from the array",
                      "const role = [\"user\", \"admin\", \"'guest'\"];",
                      "const randomRole = role[Math.floor(Math.random() * role.length)];",
                      "pm.collectionVariables.set(\"SelectRandomRole\", randomRole)",
                      "",
                      "// Select random department from avaiable list",
                      "const department = [\"QA\", \"Java\", \"Devops\", \"FE\"];",
                      "const randomDepartment = department[Math.floor(Math.random() * department.length)];",
                      "pm.collectionVariables.set(\"SelectRandomDepartmentName\", randomDepartment)",
                      ""
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{accessToken}}"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n    \"name\": \"{{$randomFirstName}}\",\n    \"email\": \"{{$randomEmail}}\",\n    \"password\": \"{{$randomPassword}}\",\n    \"role\": \"{{SelectRandomRole}}\",\n    \"department\": \"{{SelectRandomDepartmentName}}\"\n}"
                },
                "url": {
                  "raw": "{{restBase}}/users",
                  "host": [
                    "{{restBase}}"
                  ],
                  "path": [
                    "users"
                  ]
                }
              },
              "response": []
