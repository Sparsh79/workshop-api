            {
              "name": "PUT_Update_Existing_User",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 200 for PUT request', () => pm.response.to.have.status(200));",
                      "",
                      "const r = pm.response.json();",
                      "pm.test('No password', () => pm.expect(r.password).to.be.undefined);",
                      "pm.test('Role should be moderator', () => pm.expect(r.role).to.be.equal(\"moderator\"));",
                      "pm.test('Email should be present and match the email format', () => pm.expect(r.email).to.be.match(/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/));",
                      "pm.test(\"department should be Frontend\", () => pm.expect(r.department).to.be.equal(\"Frontend\"));",
                      "pm.test(\"createdAt and updatedAt should be present and match the date format\", () => {",
                      "    pm.expect(r.createdAt).to.match(/^\\d{4}-\\d{2}-\\d{2}T\\d{2}/);",
                      "    pm.expect(r.updatedAt).to.match(/^\\d{4}-\\d{2}-\\d{2}T\\d{2}/);",
                      "});",
                      "",
                      "pm.test(\"Validate response schema\", function () {",
                      "    const schema = {",
                      "        type: \"object\",",
                      "        required: [",
                      "            \"id\", \"name\", \"email\", \"role\", \"department\",",
                      "            \"avatar\", \"isActive\", \"apiKey\", \"createdAt\", \"updatedAt\"",
                      "        ],",
                      "        properties: {",
                      "            id: { type: \"string\" },",
                      "            name: { type: \"string\" },",
                      "            email: { type: \"string\", format: \"email\" },",
                      "            role: { type: \"string\" },",
                      "            department: { type: \"string\" },",
                      "            avatar: { type: \"string\", format: \"uri\" },",
                      "            isActive: { type: \"boolean\" },",
                      "            apiKey: { type: \"string\" },",
                      "            createdAt: { type: \"string\", format: \"date-time\" },",
                      "            updatedAt: { type: \"string\", format: \"date-time\" }",
                      "        }",
                      "    };",
                      "",
                      "    pm.expect(pm.response.json()).to.have.jsonSchema(schema);",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                },
                {
                  "listen": "prerequest",
                  "script": {
                    "exec": [
                      "pm.sendRequest({",
                      "    url: `${pm.collectionVariables.get(\"restBase\")}/users`,",
                      "    method: \"POST\",",
                      "    header: {",
                      "        \"Content-Type\": \"application/json\",",
                      "        \"Authorization\": `Bearer ${pm.collectionVariables.get(\"accessToken\")}`",
                      "    },",
                      "    body: {",
                      "        mode: \"raw\",",
                      "        raw: JSON.stringify({",
                      "            \"name\": \"name\",",
                      "            \"email\": \"Email\",",
                      "            \"password\": \"UpdatedPassword\",",
                      "            \"role\": \"User\",",
                      "            \"department\": \"Devops\"",
                      "        })",
                      "    }",
                      "}, function (err, res) {",
                      "    const json = res.json();",
                      "    pm.test(\"status code should be 201 for POST User\", function () {",
                      "        pm.expect(res.code).to.eql(201);",
                      "    })",
                      "    pm.collectionVariables.set(\"createdUserId\", json.id);",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "PUT",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{accessToken}}"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n    \"name\": \"Updated User\",\n    \"email\": \"testuser@example.com\",\n    \"role\": \"moderator\",\n    \"department\": \"Frontend\",\n    \"isActive\": false\n}"
                },
                "url": {
